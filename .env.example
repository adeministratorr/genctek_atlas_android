# ==========================================
# ATLAS APPLET ENVIRONMENTS & SECRETS
# Bu dosyadaki anahtarları .env dosyasında tanımlayıp değerlerini doldurabilirsiniz.
# .env dosyası git tarafından takip edilmez, böylece api anahtarlarınız güvende kalır.
# ==========================================

# Gemini Yapay Zeka API Anahtarı (Yapay Zeka özellikleri için gereklidir)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Entegrasyon Anahtarları (Manuel ilklendirme veya servisler için)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_APPLICATION_ID=your_firebase_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
FIREBASE_DATABASE_URL=your_database_url_here

# Google Haritalar API Anahtarı (Harita entegrasyonu için gerekirse)
MAPS_API_KEY=your_maps_api_key_here

# Diğer Sunucu/Servis Entegrasyonları
CUSTOM_BACKEND_URL=https://api.yourbackend.com
